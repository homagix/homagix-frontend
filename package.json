{
  "name": "homagix-frontend",
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "msw": "esbuild --platform=node --bundle src/msw.ts | node",
    "lint": "eslint src/**/*.{ts,vue}",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "npm run test:unit -- --coverage",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "update": "npx -y npm-check-updates -du",
    "postinstall": "msw init public --save"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "6.6.0",
    "@oruga-ui/oruga-next": "0.8.12",
    "@oruga-ui/theme-bulma": "0.4.3",
    "vue": "3.5.12"
  },
  "devDependencies": {
    "@types/node": "22.7.6",
    "@types/showdown": "2.0.6",
    "@typescript-eslint/eslint-plugin": "8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitejs/plugin-vue": "5.1.4",
    "@vitest/coverage-v8": "^2.1.3",
    "@vue/test-utils": "2.4.6",
    "canvas": "github:jschirrmacher/canvas",
    "esbuild": "0.24.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-vue": "9.29.0",
    "graphql": "16.9.0",
    "happy-dom": "^15.7.4",
    "jwt-decode": "4.0.0",
    "msw": "^2.4.11",
    "prettier": "3.3.3",
    "prettier-eslint": "16.3.0",
    "sass": "1.80.2",
    "typescript": "5.6.3",
    "vite": "5.4.9",
    "vitest": "2.1.3",
    "vue-router": "4.4.5",
    "vue-showdown": "4.2.0",
    "vue-tsc": "2.1.6",
    "vuex": "4.1.0",
    "wordcloud": "1.2.2"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
